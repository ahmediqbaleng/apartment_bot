<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="diff_drive_robot">
    
    <static>false</static>

    <link name="base_link">
      <pose>0 0 0.1 0 0 0</pose>
      
      <visual name="chassis_visual">
        <geometry>
          <box><size>0.4 0.2 0.1</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1.0</ambient>   <diffuse>1.0 0.0 0.0 1.0</diffuse>   <specular>0.5 0.5 0.5 1.0</specular> </material>
        </visual>

      <collision name="chassis_collision">
        <geometry>
          <box><size>0.4 0.2 0.1</size></box>
        </geometry>
      </collision>

      <inertial>
        <mass>2.0</mass>
      </inertial>
    </link>

    <link name="left_wheel">
      <pose>0.1 0.12 0.1 -1.5707 0 0</pose> <visual name="left_wheel_visual">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
        <material><ambient>0.1 0.1 0.1 1.0</ambient></material> </visual>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
      </collision>
      <inertial><mass>0.5</mass></inertial>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

<!-- right wheel configuration -->
    <link name="right_wheel">
      <pose>0.1 -0.12 0.1 -1.5707 0 0</pose> <visual name="right_wheel_visual">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
        <material><ambient>0.1 0.1 0.1 1.0</ambient></material> </visual>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
      </collision>
      <inertial><mass>0.5</mass></inertial>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

<!-- caster wheel configuration -->
    <link name="caster_wheel">
      <pose>-0.15 0.0 0.05 0 0 0</pose> <visual name="caster_wheel_visual">
        <geometry>
          <sphere><radius>0.05</radius></sphere>
        </geometry>
        <material><ambient>0.1 0.1 0.1 1.0</ambient></material> </visual>
      <collision name="caster_collision">
        <geometry>
          <sphere><radius>0.05</radius></sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.0</mu>
              <mu2>0.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <inertial><mass>0.1</mass></inertial>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_wheel</child>
    </joint>

    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

  </model>
</sdf>