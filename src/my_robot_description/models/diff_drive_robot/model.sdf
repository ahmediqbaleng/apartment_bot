<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="diff_drive_robot">
    
    <static>false</static>

    <link name="base_link">
      <pose>0 0 0.1 0 0 0</pose>
      
      <visual name="chassis_visual">
        <geometry>
          <box><size>0.4 0.2 0.1</size></box>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1.0</ambient>   <diffuse>1.0 0.0 0.0 1.0</diffuse>   <specular>0.5 0.5 0.5 1.0</specular> 
        </material>
      </visual>

      <collision name="chassis_collision">
        <geometry>
          <box><size>0.4 0.2 0.1</size></box>
        </geometry>
      </collision>

      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.008333</ixx>
          <iyy>0.028333</iyy>
          <izz>0.033333</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

<link name="left_wheel">
      <pose>0.1 0.12 0.1 -1.5707 0 0</pose> 
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
        <material><ambient>0.1 0.1 0.1 1.0</ambient></material> 
      </visual>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
      </collision>
      <inertial>
        <mass>0.5</mass>
        <inertia>
            <ixx>0.001316</ixx>
            <iyy>0.001316</iyy>
            <izz>0.002500</izz>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyz>0.0</iyz>
          </inertia>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

<link name="right_wheel">
      <pose>0.1 -0.12 0.1 -1.5707 0 0</pose> 
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
        <material><ambient>0.1 0.1 0.1 1.0</ambient></material> 
      </visual>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder><radius>0.1</radius><length>0.04</length></cylinder>
        </geometry>
      </collision>
      <inertial>
        <mass>0.5</mass>
        <inertia>
            <ixx>0.001316</ixx>
            <iyy>0.001316</iyy>
            <izz>0.002500</izz>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyz>0.0</iyz>
          </inertia>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

<link name="caster_wheel">
      <pose>-0.15 0.0 0.05 0 0 0</pose> 
      <visual name="caster_wheel_visual">
        <geometry>
          <sphere><radius>0.05</radius></sphere>
        </geometry>
        <material><ambient>0.1 0.1 0.1 1.0</ambient></material> 
      </visual>
      <collision name="caster_collision">
        <geometry>
          <sphere><radius>0.05</radius></sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.0</mu>
              <mu2>0.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <iyy>0.0001</iyy>
          <izz>0.0001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_wheel</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <topic>/cmd_vel</topic> 
    </plugin>

<link name="lidar_link">
      <pose>0 0 0.25 0 0 0</pose> 
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.0 0.0 0.0 1.0</ambient>
          <diffuse>0.0 0.0 0.0 1.0</diffuse>
        </material>
      </visual>
      
      <!-- <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision> -->
      
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <iyy>0.0001</iyy>
          <izz>0.0001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0 0 0.03 0 0 0</pose> 
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <topic>/scan</topic>
        <frame_id>lidar_link</frame_id> 
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1.0</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>8.0</max>
            <resolution>0.015</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

  </model>
</sdf>